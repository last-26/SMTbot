//@version=6
indicator("Signal Table", overlay=true, max_labels_count=500, max_lines_count=200)

// ─── INPUTS ───────────────────────────────────────────────────────────────────
swingLen       = input.int(5, "Swing Lookback", minval=2, maxval=50, group="Structure")
minFVGPct      = input.float(0.0, "Min FVG Size (%)", minval=0.0, step=0.05, group="FVG")
eqThreshold    = input.float(0.05, "Equal Level Threshold (%)", minval=0.01, maxval=0.5, step=0.01, group="Liquidity")
minImpulseATR  = input.float(1.5, "Min Impulse (ATR mult)", minval=0.5, step=0.1, group="Order Blocks")
htfTF          = input.timeframe("240", "HTF Timeframe", group="Multi-TF")

// Session times (UTC)
asianSession   = input.session("2000-0000", "Asian Session", group="Sessions")
londonSession  = input.session("0700-1600", "London Session", group="Sessions")
nySession      = input.session("1200-2100", "NY Session", group="Sessions")

// ─── ATR ──────────────────────────────────────────────────────────────────────
atrVal = ta.atr(14)

// ═══════════════════════════════════════════════════════════════════════════════
// MARKET STRUCTURE (MSS/BOS detection — same logic as mss_detector.pine)
// ═══════════════════════════════════════════════════════════════════════════════
swingHigh = ta.pivothigh(high, swingLen, swingLen)
swingLow  = ta.pivotlow(low, swingLen, swingLen)

var float lastSH    = na
var float lastSL    = na
var string lastHType = na   // HH or LH
var string lastLType = na   // HL or LL
var int trend       = 0     // 1=bull, -1=bear
var float lastMSSPrice = na
var string lastMSSDir  = na
var int lastMSSBar  = 0

// Process swing highs
if not na(swingHigh)
    if not na(lastSH)
        lastHType := swingHigh > lastSH ? "HH" : "LH"
    lastSH := swingHigh

// Process swing lows
if not na(swingLow)
    if not na(lastSL)
        lastLType := swingLow > lastSL ? "HL" : "LL"
    lastSL := swingLow

// Initial trend
if trend == 0
    if lastHType == "HH" and lastLType == "HL"
        trend := 1
    else if lastHType == "LH" and lastLType == "LL"
        trend := -1

// MSS detection
if not na(swingHigh) and lastHType == "HH" and trend == -1
    swingBar = bar_index - swingLen
    if swingBar != lastMSSBar
        trend       := 1
        lastMSSBar  := swingBar
        lastMSSPrice := swingHigh
        lastMSSDir  := "BULLISH"

if not na(swingLow) and lastLType == "LL" and trend == 1
    swingBar = bar_index - swingLen
    if swingBar != lastMSSBar
        trend       := -1
        lastMSSBar  := swingBar
        lastMSSPrice := swingLow
        lastMSSDir  := "BEARISH"

// Structure string
structureStr = na(lastHType) ? "—" : lastHType + "_" + (na(lastLType) ? "" : lastLType) + (trend == 1 ? "_bullish" : trend == -1 ? "_bearish" : "")

// ═══════════════════════════════════════════════════════════════════════════════
// HTF TREND (from higher timeframe)
// ═══════════════════════════════════════════════════════════════════════════════
htfHigh = request.security(syminfo.tickerid, htfTF, high, lookahead=barmerge.lookahead_off)
htfLow  = request.security(syminfo.tickerid, htfTF, low, lookahead=barmerge.lookahead_off)
htfClose = request.security(syminfo.tickerid, htfTF, close, lookahead=barmerge.lookahead_off)
htfOpen  = request.security(syminfo.tickerid, htfTF, open, lookahead=barmerge.lookahead_off)

// Simple HTF trend: EMA-based
htfEmaFast = request.security(syminfo.tickerid, htfTF, ta.ema(close, 9), lookahead=barmerge.lookahead_off)
htfEmaSlow = request.security(syminfo.tickerid, htfTF, ta.ema(close, 21), lookahead=barmerge.lookahead_off)

htfTrend = htfEmaFast > htfEmaSlow ? "BULLISH" : htfEmaFast < htfEmaSlow ? "BEARISH" : "RANGING"

// ═══════════════════════════════════════════════════════════════════════════════
// FVG DETECTION (active FVGs near price)
// ═══════════════════════════════════════════════════════════════════════════════
var array<float> fvgTops    = array.new<float>()
var array<float> fvgBots    = array.new<float>()
var array<int>   fvgDirs    = array.new<int>()
var array<int>   fvgBarsArr = array.new<int>()

// Bullish FVG
c1h = high[2]
c3l = low[0]
isBullFVG = c3l > c1h and ((c3l - c1h) / c1h * 100) >= minFVGPct
if isBullFVG
    array.push(fvgTops, c3l)
    array.push(fvgBots, c1h)
    array.push(fvgDirs, 1)
    array.push(fvgBarsArr, bar_index)

// Bearish FVG
c1l = low[2]
c3h = high[0]
isBearFVG = c1l > c3h and ((c1l - c3h) / c3h * 100) >= minFVGPct
if isBearFVG
    array.push(fvgTops, c1l)
    array.push(fvgBots, c3h)
    array.push(fvgDirs, -1)
    array.push(fvgBarsArr, bar_index)

// Cleanup & find nearest active FVGs
nearestBullFVG = ""
nearestBearFVG = ""
nearestBullDist = 999999999.0
nearestBearDist = 999999999.0
activeBullFVGs = 0
activeBearFVGs = 0

if array.size(fvgTops) > 0
    for i = array.size(fvgTops) - 1 to 0
        age = bar_index - array.get(fvgBarsArr, i)
        top = array.get(fvgTops, i)
        bot = array.get(fvgBots, i)
        dir = array.get(fvgDirs, i)

        // Check mitigation
        mitigated = dir == 1 ? low <= bot : high >= top

        if age > 100 or mitigated
            array.remove(fvgTops, i)
            array.remove(fvgBots, i)
            array.remove(fvgDirs, i)
            array.remove(fvgBarsArr, i)
            continue

        mid = (top + bot) / 2
        dist = math.abs(close - mid)

        if dir == 1
            activeBullFVGs += 1
            if dist < nearestBullDist
                nearestBullDist := dist
                nearestBullFVG := "BULL@" + str.tostring(bot, "#.##") + "-" + str.tostring(top, "#.##")
        else
            activeBearFVGs += 1
            if dist < nearestBearDist
                nearestBearDist := dist
                nearestBearFVG := "BEAR@" + str.tostring(bot, "#.##") + "-" + str.tostring(top, "#.##")

// ═══════════════════════════════════════════════════════════════════════════════
// ORDER BLOCK DETECTION (simplified — nearest active OBs)
// ═══════════════════════════════════════════════════════════════════════════════
var array<float> obTops    = array.new<float>()
var array<float> obBots    = array.new<float>()
var array<int>   obDirsArr = array.new<int>()
var array<int>   obBarsArr = array.new<int>()

// Bullish OB
if not na(swingLow)
    impulseSize = high[0] - swingLow
    if impulseSize > atrVal * minImpulseATR
        for j = swingLen to swingLen + 5
            if close[j] < open[j]
                array.push(obTops, high[j])
                array.push(obBots, low[j])
                array.push(obDirsArr, 1)
                array.push(obBarsArr, bar_index)
                break

// Bearish OB
if not na(swingHigh)
    impulseSize = swingHigh - low[0]
    if impulseSize > atrVal * minImpulseATR
        for j = swingLen to swingLen + 5
            if close[j] > open[j]
                array.push(obTops, high[j])
                array.push(obBots, low[j])
                array.push(obDirsArr, -1)
                array.push(obBarsArr, bar_index)
                break

// Cleanup & find nearest OBs
nearestBullOB = ""
nearestBearOB = ""
nearestBullOBDist = 999999999.0
nearestBearOBDist = 999999999.0

if array.size(obTops) > 0
    for i = array.size(obTops) - 1 to 0
        age = bar_index - array.get(obBarsArr, i)
        top = array.get(obTops, i)
        bot = array.get(obBots, i)
        dir = array.get(obDirsArr, i)

        // Break check
        broken = dir == 1 ? close < bot : close > top

        if age > 200 or broken
            array.remove(obTops, i)
            array.remove(obBots, i)
            array.remove(obDirsArr, i)
            array.remove(obBarsArr, i)
            continue

        mid = (top + bot) / 2
        dist = math.abs(close - mid)

        if dir == 1 and dist < nearestBullOBDist
            nearestBullOBDist := dist
            nearestBullOB := "BULL@" + str.tostring(bot, "#.##") + "-" + str.tostring(top, "#.##")
        if dir == -1 and dist < nearestBearOBDist
            nearestBearOBDist := dist
            nearestBearOB := "BEAR@" + str.tostring(bot, "#.##") + "-" + str.tostring(top, "#.##")

// ═══════════════════════════════════════════════════════════════════════════════
// LIQUIDITY LEVELS (equal highs/lows tracking)
// ═══════════════════════════════════════════════════════════════════════════════
var array<float> eqHighs      = array.new<float>()
var array<int>   eqHighCounts = array.new<int>()
var array<float> eqLows       = array.new<float>()
var array<int>   eqLowCounts  = array.new<int>()

// Track equal highs
if not na(swingHigh)
    matched = false
    if array.size(eqHighs) > 0
        for i = 0 to array.size(eqHighs) - 1
            diff = math.abs(swingHigh - array.get(eqHighs, i)) / array.get(eqHighs, i) * 100
            if diff <= eqThreshold
                count = array.get(eqHighCounts, i) + 1
                array.set(eqHighCounts, i, count)
                newLevel = (array.get(eqHighs, i) * (count - 1) + swingHigh) / count
                array.set(eqHighs, i, newLevel)
                matched := true
                break
    if not matched
        array.push(eqHighs, swingHigh)
        array.push(eqHighCounts, 1)

// Track equal lows
if not na(swingLow)
    matched = false
    if array.size(eqLows) > 0
        for i = 0 to array.size(eqLows) - 1
            diff = math.abs(swingLow - array.get(eqLows, i)) / array.get(eqLows, i) * 100
            if diff <= eqThreshold
                count = array.get(eqLowCounts, i) + 1
                array.set(eqLowCounts, i, count)
                newLevel = (array.get(eqLows, i) * (count - 1) + swingLow) / count
                array.set(eqLows, i, newLevel)
                matched := true
                break
    if not matched
        array.push(eqLows, swingLow)
        array.push(eqLowCounts, 1)

// Find liquidity levels above and below price (with 2+ touches)
liqAbove = ""
liqBelow = ""
liqAboveCount = 0
liqBelowCount = 0

if array.size(eqHighs) > 0
    for i = 0 to array.size(eqHighs) - 1
        if array.get(eqHighCounts, i) >= 2 and array.get(eqHighs, i) > close
            if liqAbove == ""
                liqAbove := str.tostring(array.get(eqHighs, i), "#.##")
            else
                liqAbove += "," + str.tostring(array.get(eqHighs, i), "#.##")
            liqAboveCount += 1
            if liqAboveCount >= 3
                break

if array.size(eqLows) > 0
    for i = 0 to array.size(eqLows) - 1
        if array.get(eqLowCounts, i) >= 2 and array.get(eqLows, i) < close
            if liqBelow == ""
                liqBelow := str.tostring(array.get(eqLows, i), "#.##")
            else
                liqBelow += "," + str.tostring(array.get(eqLows, i), "#.##")
            liqBelowCount += 1
            if liqBelowCount >= 3
                break

// ═══════════════════════════════════════════════════════════════════════════════
// SWEEP DETECTION (last sweep)
// ═══════════════════════════════════════════════════════════════════════════════
var string lastSweep = "—"

// Bearish sweep (above equal highs)
if array.size(eqHighs) > 0
    for i = 0 to array.size(eqHighs) - 1
        level = array.get(eqHighs, i)
        if array.get(eqHighCounts, i) >= 2 and high > level and close < level
            lastSweep := "BEAR@" + str.tostring(level, "#.##")
            break

// Bullish sweep (below equal lows)
if array.size(eqLows) > 0
    for i = 0 to array.size(eqLows) - 1
        level = array.get(eqLows, i)
        if array.get(eqLowCounts, i) >= 2 and low < level and close > level
            lastSweep := "BULL@" + str.tostring(level, "#.##")
            break

// ═══════════════════════════════════════════════════════════════════════════════
// SESSION INFO
// ═══════════════════════════════════════════════════════════════════════════════
isAsian  = not na(time(timeframe.period, asianSession, "UTC"))
isLondon = not na(time(timeframe.period, londonSession, "UTC"))
isNY     = not na(time(timeframe.period, nySession, "UTC"))

activeSession = isAsian ? "ASIAN" : isLondon ? "LONDON" : isNY ? "NEW_YORK" : "OFF"

// ═══════════════════════════════════════════════════════════════════════════════
// CONFLUENCE SCORE
// ═══════════════════════════════════════════════════════════════════════════════
confluenceScore = 0

// 1. HTF trend alignment with LTF
if (htfTrend == "BULLISH" and trend == 1) or (htfTrend == "BEARISH" and trend == -1)
    confluenceScore += 1

// 2. Price near an OB or FVG
priceNearBullOB = nearestBullOBDist < atrVal * 2 and trend == 1
priceNearBearOB = nearestBearOBDist < atrVal * 2 and trend == -1
priceNearBullFVG = nearestBullDist < atrVal * 2 and trend == 1
priceNearBearFVG = nearestBearDist < atrVal * 2 and trend == -1

if priceNearBullOB or priceNearBearOB or priceNearBullFVG or priceNearBearFVG
    confluenceScore += 1

// 3. Recent MSS in signal direction
if not na(lastMSSDir) and bar_index - lastMSSBar < 50
    if (lastMSSDir == "BULLISH" and trend == 1) or (lastMSSDir == "BEARISH" and trend == -1)
        confluenceScore += 1

// 4. Sweep aligning with trend
if (str.startswith(lastSweep, "BULL") and trend == 1) or (str.startswith(lastSweep, "BEAR") and trend == -1)
    confluenceScore += 1

// 5. Active session (London or NY = more reliable)
if isLondon or isNY
    confluenceScore += 1

// ═══════════════════════════════════════════════════════════════════════════════
// MASTER SIGNAL TABLE — bot reads via `tv stream tables --filter "Signals"`
// ═══════════════════════════════════════════════════════════════════════════════
var table sigTable = table.new(position.top_right, 2, 14, bgcolor=color.new(color.black, 75), border_width=1)

bullCol = color.new(#00C853, 0)
bearCol = color.new(#FF1744, 0)
neutCol = color.gray

if barstate.islast
    trendCol = trend == 1 ? bullCol : trend == -1 ? bearCol : neutCol
    htfCol   = htfTrend == "BULLISH" ? bullCol : htfTrend == "BEARISH" ? bearCol : neutCol
    confCol  = confluenceScore >= 3 ? bullCol : confluenceScore >= 2 ? color.yellow : bearCol

    row = 0

    table.cell(sigTable, 0, row, "=== SIGNALS ===",   text_color=color.white, text_size=size.small)
    table.cell(sigTable, 1, row, syminfo.ticker,       text_color=color.white, text_size=size.small)
    row += 1

    table.cell(sigTable, 0, row, "trend_htf",          text_color=neutCol, text_size=size.small)
    table.cell(sigTable, 1, row, htfTrend,             text_color=htfCol,  text_size=size.small)
    row += 1

    table.cell(sigTable, 0, row, "trend_ltf",          text_color=neutCol, text_size=size.small)
    trendLTF = trend == 1 ? "BULLISH" : trend == -1 ? "BEARISH" : "UNDEFINED"
    table.cell(sigTable, 1, row, trendLTF,             text_color=trendCol, text_size=size.small)
    row += 1

    table.cell(sigTable, 0, row, "structure",          text_color=neutCol, text_size=size.small)
    table.cell(sigTable, 1, row, structureStr,         text_color=trendCol, text_size=size.small)
    row += 1

    table.cell(sigTable, 0, row, "last_mss",           text_color=neutCol, text_size=size.small)
    mssStr = na(lastMSSDir) ? "—" : lastMSSDir + "@" + str.tostring(lastMSSPrice, "#.##")
    mssCol = lastMSSDir == "BULLISH" ? bullCol : lastMSSDir == "BEARISH" ? bearCol : neutCol
    table.cell(sigTable, 1, row, mssStr,               text_color=mssCol,  text_size=size.small)
    row += 1

    table.cell(sigTable, 0, row, "active_fvg",         text_color=neutCol, text_size=size.small)
    fvgStr = nearestBullFVG != "" ? nearestBullFVG : nearestBearFVG != "" ? nearestBearFVG : "—"
    table.cell(sigTable, 1, row, fvgStr,               text_color=color.white, text_size=size.small)
    row += 1

    table.cell(sigTable, 0, row, "active_ob",          text_color=neutCol, text_size=size.small)
    obStr = nearestBullOB != "" ? nearestBullOB : nearestBearOB != "" ? nearestBearOB : "—"
    table.cell(sigTable, 1, row, obStr,                text_color=color.white, text_size=size.small)
    row += 1

    table.cell(sigTable, 0, row, "liquidity_above",    text_color=neutCol, text_size=size.small)
    table.cell(sigTable, 1, row, liqAbove == "" ? "—" : liqAbove, text_color=bearCol, text_size=size.small)
    row += 1

    table.cell(sigTable, 0, row, "liquidity_below",    text_color=neutCol, text_size=size.small)
    table.cell(sigTable, 1, row, liqBelow == "" ? "—" : liqBelow, text_color=bullCol, text_size=size.small)
    row += 1

    table.cell(sigTable, 0, row, "last_sweep",         text_color=neutCol, text_size=size.small)
    sweepCol = str.startswith(lastSweep, "BULL") ? bullCol : str.startswith(lastSweep, "BEAR") ? bearCol : neutCol
    table.cell(sigTable, 1, row, lastSweep,            text_color=sweepCol, text_size=size.small)
    row += 1

    table.cell(sigTable, 0, row, "session",            text_color=neutCol, text_size=size.small)
    sessionCol = isLondon ? color.new(#2196F3, 0) : isNY ? color.new(#FF9800, 0) : isAsian ? color.new(#9C27B0, 0) : neutCol
    table.cell(sigTable, 1, row, activeSession,        text_color=sessionCol, text_size=size.small)
    row += 1

    table.cell(sigTable, 0, row, "confluence",         text_color=neutCol, text_size=size.small)
    table.cell(sigTable, 1, row, str.tostring(confluenceScore) + "/5", text_color=confCol, text_size=size.small)
    row += 1

    table.cell(sigTable, 0, row, "atr_14",             text_color=neutCol, text_size=size.small)
    table.cell(sigTable, 1, row, str.tostring(atrVal, "#.##"), text_color=color.white, text_size=size.small)
    row += 1

    table.cell(sigTable, 0, row, "price",              text_color=neutCol, text_size=size.small)
    table.cell(sigTable, 1, row, str.tostring(close, "#.##"), text_color=color.white, text_size=size.small)
