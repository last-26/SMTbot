//
// SMT Master Oscillator — VMC Cipher B (Divergences) in Pine v6 + bot data table
// Combines: WaveTrend + VWAP + RSI + MFI + Stochastic RSI + Divergences (WT/RSI/Stoch, reg+hidden) + Schaff TC
// Ported from Pine v4 (VMC Cipher B / VuManChu) → Pine v6.
//
// Bot reads via:  tv stream tables --filter "SMT Oscillator"

//@version=6
indicator("SMT Master Oscillator",
          shorttitle="SMT Osc",
          overlay=false,
          format=format.price,
          precision=2)

// ═══════════════════════════════════════════════════════════════════════════════
// MODULE TOGGLES
// ═══════════════════════════════════════════════════════════════════════════════
showWT          = input.bool(true,  "Show WaveTrend",               group="Modules")
showVWAP        = input.bool(true,  "Show Fast WT (WT1-WT2)",       group="Modules")
showMFI         = input.bool(true,  "Show RSI+MFI Area",            group="Modules")
showRSI         = input.bool(false, "Show RSI line",                group="Modules")
showStoch       = input.bool(true,  "Show Stochastic RSI",          group="Modules")
showSchaff      = input.bool(false, "Show Schaff TC line",          group="Modules")
showBuyDots     = input.bool(true,  "Show Buy dots",                group="Modules")
showSellDots    = input.bool(true,  "Show Sell dots",               group="Modules")
showGoldDots    = input.bool(true,  "Show Gold dots",               group="Modules")
showDivDots     = input.bool(true,  "Show Divergence dots",         group="Modules")
showSmallCross  = input.bool(true,  "Show small WT-cross circle",   group="Modules")
showTable       = input.bool(true,  "Show Oscillator Table",        group="Modules")
darkMode        = input.bool(false, "Dark Mode Background",         group="Modules")

// ═══════════════════════════════════════════════════════════════════════════════
// WAVETREND
// ═══════════════════════════════════════════════════════════════════════════════
wtChannelLen   = input.int(9,   "WT Channel Length",    group="WaveTrend")
wtAverageLen   = input.int(12,  "WT Average Length",    group="WaveTrend")
wtMASource     = input.source(hlc3, "WT MA Source",     group="WaveTrend")
wtMALen        = input.int(3,   "WT MA Length",         group="WaveTrend")

obLevel        = input.int(53,  "WT Overbought Level 1", group="WT Levels")
obLevel2       = input.int(60,  "WT Overbought Level 2", group="WT Levels")
obLevel3       = input.int(100, "WT Overbought Level 3", group="WT Levels")
osLevel        = input.int(-53, "WT Oversold Level 1",   group="WT Levels")
osLevel2       = input.int(-60, "WT Oversold Level 2",   group="WT Levels")
osLevel3       = input.int(-75, "WT Oversold Level 3",   group="WT Levels")

// ═══════════════════════════════════════════════════════════════════════════════
// DIVERGENCES
// ═══════════════════════════════════════════════════════════════════════════════
wtShowDiv          = input.bool(true,  "WT Regular Divergences",            group="Divergences")
wtShowHiddenDiv    = input.bool(false, "WT Hidden Divergences",             group="Divergences")
showHiddenDivNoLim = input.bool(true,  "Hidden Div: Ignore OB/OS Limits",   group="Divergences")
wtDivOBLevel       = input.int(45,  "WT Bearish Divergence min",            group="Divergences")
wtDivOSLevel       = input.int(-65, "WT Bullish Divergence min",            group="Divergences")

wtDivOBLevelAddShow = input.bool(true, "Show 2nd WT Divergences",           group="Divergences")
wtDivOBLevelAdd     = input.int(15,  "WT 2nd Bearish Divergence",           group="Divergences")
wtDivOSLevelAdd     = input.int(-40, "WT 2nd Bullish Divergence",           group="Divergences")

// ═══════════════════════════════════════════════════════════════════════════════
// RSI + MFI
// ═══════════════════════════════════════════════════════════════════════════════
rsiMFIPeriod     = input.int(60,  "RSI+MFI Period",       group="RSI+MFI")
rsiMFIMultiplier = input.float(150, "RSI+MFI Multiplier", group="RSI+MFI")
rsiMFIPosY       = input.float(2.5, "RSI+MFI Y Position", group="RSI+MFI")

// ═══════════════════════════════════════════════════════════════════════════════
// RSI
// ═══════════════════════════════════════════════════════════════════════════════
rsiSRC           = input.source(close, "RSI Source",     group="RSI")
rsiLen           = input.int(14,  "RSI Length",          group="RSI")
rsiOversold      = input.int(30,  "RSI Oversold",  minval=0, maxval=50,  group="RSI")
rsiOverbought    = input.int(60,  "RSI Overbought", minval=50, maxval=100, group="RSI")

rsiShowDiv       = input.bool(false, "RSI Regular Divergences", group="RSI")
rsiShowHiddenDiv = input.bool(false, "RSI Hidden Divergences",  group="RSI")
rsiDivOBLevel    = input.int(60, "RSI Bearish Div Min", group="RSI")
rsiDivOSLevel    = input.int(30, "RSI Bullish Div Min", group="RSI")

// ═══════════════════════════════════════════════════════════════════════════════
// STOCHASTIC RSI
// ═══════════════════════════════════════════════════════════════════════════════
stochUseLog      = input.bool(true,  "Stoch RSI: Use log of source", group="Stoch RSI")
stochAvgKD       = input.bool(false, "Stoch RSI: Avg of K and D",    group="Stoch RSI")
stochSRC         = input.source(close, "Stoch RSI Source",           group="Stoch RSI")
stochLen         = input.int(14, "Stochastic Length",                 group="Stoch RSI")
stochRsiLen      = input.int(14, "RSI Length (inner)",                group="Stoch RSI")
stochKSmooth     = input.int(3,  "K Smooth",                          group="Stoch RSI")
stochDSmooth     = input.int(3,  "D Smooth",                          group="Stoch RSI")

stochShowDiv     = input.bool(false, "Stoch Regular Divergences", group="Stoch RSI")
stochShowHiddenDiv = input.bool(false, "Stoch Hidden Divergences", group="Stoch RSI")

// ═══════════════════════════════════════════════════════════════════════════════
// SCHAFF TREND CYCLE
// ═══════════════════════════════════════════════════════════════════════════════
tcSRC        = input.source(close, "Schaff TC Source",   group="Schaff TC")
tcLength     = input.int(10, "Schaff TC Length",         group="Schaff TC")
tcFastLength = input.int(23, "Schaff TC Fast Length",    group="Schaff TC")
tcSlowLength = input.int(50, "Schaff TC Slow Length",    group="Schaff TC")
tcFactor     = input.float(0.5, "Schaff TC Factor",      group="Schaff TC")

// ═══════════════════════════════════════════════════════════════════════════════
// COLORS
// ═══════════════════════════════════════════════════════════════════════════════
colorRed       = #ff0000
colorGreen     = #3fff00
colorOrange    = #e2a400
colorYellow    = #ffe500
colorWhite     = #ffffff
colorPurple    = #e600e6
colorPink      = #ff00f0
colorBluelight = #31c0ff

colorWT1       = #90caf9
colorWT2       = #0d47a1
colorWT2_dark  = #131722

// ═══════════════════════════════════════════════════════════════════════════════
// FUNCTIONS
// ═══════════════════════════════════════════════════════════════════════════════

// 5-bar fractal top/bottom — used for divergence detection
f_topFractal(src)  => src[4] < src[2] and src[3] < src[2] and src[2] > src[1] and src[2] > src[0]
f_botFractal(src)  => src[4] > src[2] and src[3] > src[2] and src[2] < src[1] and src[2] < src[0]
f_fractalize(src)  => f_topFractal(src) ? 1 : f_botFractal(src) ? -1 : 0

// Divergence detector (VMC B original logic)
// Returns: [fractalTop, fractalBot, lowPrev, bearRegular, bullRegular, bearHidden, bullHidden]
f_findDivs(src, topLimit, botLimit, useLimits) =>
    fractalTop = f_fractalize(src) > 0 and (useLimits ? src[2] >= topLimit : true) ? src[2] : na
    fractalBot = f_fractalize(src) < 0 and (useLimits ? src[2] <= botLimit : true) ? src[2] : na
    highPrev   = ta.valuewhen(not na(fractalTop), src[2],  0)[2]
    highPrice  = ta.valuewhen(not na(fractalTop), high[2], 0)[2]
    lowPrev    = ta.valuewhen(not na(fractalBot), src[2],  0)[2]
    lowPrice   = ta.valuewhen(not na(fractalBot), low[2],  0)[2]
    bearSignal     = not na(fractalTop) and high[2] > highPrice and src[2] < highPrev
    bullSignal     = not na(fractalBot) and low[2]  < lowPrice  and src[2] > lowPrev
    bearDivHidden  = not na(fractalTop) and high[2] < highPrice and src[2] > highPrev
    bullDivHidden  = not na(fractalBot) and low[2]  > lowPrice  and src[2] < lowPrev
    [fractalTop, fractalBot, lowPrev, bearSignal, bullSignal, bearDivHidden, bullDivHidden]

// RSI+MFI area (VMC B)
f_rsiMfi(_period, _multiplier) =>
    ta.sma(((close - open) / (high - low)) * _multiplier, _period) - rsiMFIPosY

// WaveTrend (VMC B / LazyBear)
f_wavetrend(src, chlen, avg, malen) =>
    esa = ta.ema(src, chlen)
    de  = ta.ema(math.abs(src - esa), chlen)
    ci  = (src - esa) / (0.015 * de)
    wt1_ = ta.ema(ci, avg)
    wt2_ = ta.sma(wt1_, malen)
    wtVwap_   = wt1_ - wt2_
    wtOS      = wt2_ <= osLevel
    wtOB      = wt2_ >= obLevel
    wtCross_  = ta.cross(wt1_, wt2_)
    wtCrUp    = wt2_ - wt1_ <= 0
    wtCrDn    = wt2_ - wt1_ >= 0
    [wt1_, wt2_, wtOS, wtOB, wtCross_, wtCrUp, wtCrDn, wtVwap_]

// Schaff Trend Cycle (VMC B)
f_tc(src, length, fastLength, slowLength) =>
    ema1 = ta.ema(src, fastLength)
    ema2 = ta.ema(src, slowLength)
    macdVal = ema1 - ema2
    alpha   = ta.lowest(macdVal, length)
    beta    = ta.highest(macdVal, length) - alpha
    gamma   = beta > 0 ? (macdVal - alpha) / beta * 100 : 0.0
    var float delta = 0.0
    delta := na(delta[1]) ? gamma : delta[1] + tcFactor * (gamma - delta[1])
    epsilon = ta.lowest(delta, length)
    zeta    = ta.highest(delta, length) - epsilon
    eta     = zeta > 0 ? (delta - epsilon) / zeta * 100 : 0.0
    var float stcReturn = 0.0
    stcReturn := na(stcReturn[1]) ? eta : stcReturn[1] + tcFactor * (eta - stcReturn[1])
    stcReturn

// Stochastic RSI (VMC B)
f_stochRsi(_src, _stochlen, _rsilen, _smoothK, _smoothD, _log, _avg) =>
    src_ = _log ? math.log(_src) : _src
    rsi_ = ta.rsi(src_, _rsilen)
    k_   = ta.sma(ta.stoch(rsi_, rsi_, rsi_, _stochlen), _smoothK)
    d_   = ta.sma(k_, _smoothD)
    avg_ = (k_ + d_) / 2
    k_out = _avg ? avg_ : k_
    [k_out, d_]

// ═══════════════════════════════════════════════════════════════════════════════
// CALCULATIONS
// ═══════════════════════════════════════════════════════════════════════════════

// RSI
rsi      = ta.rsi(rsiSRC, rsiLen)
rsiColor = rsi <= rsiOversold ? color.new(colorGreen, 25) : rsi >= rsiOverbought ? color.new(colorRed, 25) : color.new(colorPurple, 25)

// RSI+MFI
rsiMFI      = f_rsiMfi(rsiMFIPeriod, rsiMFIMultiplier)
rsiMFIColor = rsiMFI > 0 ? color.new(#3ee145, 20) : color.new(#ff3d2e, 20)

// WaveTrend
[wt1, wt2, wtOversold, wtOverbought, wtCross, wtCrossUp, wtCrossDown, wtVwap] = f_wavetrend(wtMASource, wtChannelLen, wtAverageLen, wtMALen)

// Stochastic RSI
[stochK, stochD] = f_stochRsi(stochSRC, stochLen, stochRsiLen, stochKSmooth, stochDSmooth, stochUseLog, stochAvgKD)

// Schaff TC
tcVal = f_tc(tcSRC, tcLength, tcFastLength, tcSlowLength)

// WT Divergences (primary)
[wtFractalTop, wtFractalBot, wtLow_prev, wtBearDiv, wtBullDiv, wtBearDivHidden, wtBullDivHidden] = f_findDivs(wt2, wtDivOBLevel, wtDivOSLevel, true)

// WT Divergences (secondary — additional range)
[wtFractalTop_add, wtFractalBot_add, wtLowPrev_add, wtBearDiv_add, wtBullDiv_add, wtBearDivHidden_add, wtBullDivHidden_add] = f_findDivs(wt2, wtDivOBLevelAdd, wtDivOSLevelAdd, true)

// WT Divergences (no-limit — for hidden divs)
[wtFractalTop_nl, wtFractalBot_nl, wtLowPrev_nl, wtBearDiv_nl, wtBullDiv_nl, wtBearDivHidden_nl, wtBullDivHidden_nl] = f_findDivs(wt2, 0, 0, false)

wtBearDivHidden_eff = showHiddenDivNoLim ? wtBearDivHidden_nl : wtBearDivHidden
wtBullDivHidden_eff = showHiddenDivNoLim ? wtBullDivHidden_nl : wtBullDivHidden

wtBearDivColor = (wtShowDiv and wtBearDiv) or (wtShowHiddenDiv and wtBearDivHidden_eff) ? color.new(colorRed, 0) : na
wtBullDivColor = (wtShowDiv and wtBullDiv) or (wtShowHiddenDiv and wtBullDivHidden_eff) ? color.new(colorGreen, 0) : na

wtBearDivColor_add = (wtShowDiv and wtDivOBLevelAddShow and wtBearDiv_add) or (wtShowHiddenDiv and wtDivOBLevelAddShow and wtBearDivHidden_add) ? color.new(#9a0202, 0) : na
wtBullDivColor_add = (wtShowDiv and wtDivOBLevelAddShow and wtBullDiv_add) or (wtShowHiddenDiv and wtDivOBLevelAddShow and wtBullDivHidden_add) ? color.new(#1b5e20, 0) : na

// RSI Divergences
[rsiFractalTop, rsiFractalBot, rsiLowPrev, rsiBearDiv, rsiBullDiv, rsiBearDivHidden, rsiBullDivHidden] = f_findDivs(rsi, rsiDivOBLevel, rsiDivOSLevel, true)
[rsiFractalTop_nl, rsiFractalBot_nl, rsiLowPrev_nl, rsiBearDiv_nl, rsiBullDiv_nl, rsiBearDivHidden_nl, rsiBullDivHidden_nl] = f_findDivs(rsi, 0, 0, false)

rsiBearDivHidden_eff = showHiddenDivNoLim ? rsiBearDivHidden_nl : rsiBearDivHidden
rsiBullDivHidden_eff = showHiddenDivNoLim ? rsiBullDivHidden_nl : rsiBullDivHidden

rsiBearDivColor = (rsiShowDiv and rsiBearDiv) or (rsiShowHiddenDiv and rsiBearDivHidden_eff) ? color.new(colorRed, 0) : na
rsiBullDivColor = (rsiShowDiv and rsiBullDiv) or (rsiShowHiddenDiv and rsiBullDivHidden_eff) ? color.new(colorGreen, 0) : na

// Stoch Divergences
[stochFractalTop, stochFractalBot, stochLowPrev, stochBearDiv, stochBullDiv, stochBearDivHidden, stochBullDivHidden] = f_findDivs(stochK, 0, 0, false)

stochBearDivColor = (stochShowDiv and stochBearDiv) or (stochShowHiddenDiv and stochBearDivHidden) ? color.new(colorRed, 0) : na
stochBullDivColor = (stochShowDiv and stochBullDiv) or (stochShowHiddenDiv and stochBullDivHidden) ? color.new(colorGreen, 0) : na

// Small cross circle color (WT-only)
signalColor = wt2 - wt1 > 0 ? color.red : color.lime

// ═══════════════════════════════════════════════════════════════════════════════
// MAIN SIGNALS
// ═══════════════════════════════════════════════════════════════════════════════
buySignal  = wtCross and wtCrossUp   and wtOversold
sellSignal = wtCross and wtCrossDown and wtOverbought

buySignalDiv  = (wtShowDiv and wtBullDiv) or (wtShowDiv and wtBullDiv_add) or (stochShowDiv and stochBullDiv) or (rsiShowDiv and rsiBullDiv)
sellSignalDiv = (wtShowDiv and wtBearDiv) or (wtShowDiv and wtBearDiv_add) or (stochShowDiv and stochBearDiv) or (rsiShowDiv and rsiBearDiv)

buySignalDivColor  = wtBullDiv     ? color.new(colorGreen, 0) : wtBullDiv_add ? color.new(colorGreen, 60) : rsiShowDiv and rsiBullDiv ? color.new(colorGreen, 0) : na
sellSignalDivColor = wtBearDiv     ? color.new(colorRed,   0) : wtBearDiv_add ? color.new(colorRed,   60) : rsiShowDiv and rsiBearDiv ? color.new(colorRed,   0) : na

// Gold Buy: wtLow_prev <= osLevel3 AND wt2 > osLevel3 AND wtLow_prev - wt2 <= -5 AND lastRsi < 30
lastRsi  = ta.valuewhen(not na(wtFractalBot), rsi[2], 0)[2]
wtGoldBuy = ((wtShowDiv and wtBullDiv) or (rsiShowDiv and rsiBullDiv)) and wtLow_prev <= osLevel3 and wt2 > osLevel3 and (wtLow_prev - wt2) <= -5 and lastRsi < 30

// ═══════════════════════════════════════════════════════════════════════════════
// PLOTS
// ═══════════════════════════════════════════════════════════════════════════════
bgcolor(darkMode ? color.new(#000000, 80) : na)
zLine = plot(0, "Zero Line", color=color.new(colorWhite, 50))

// MFI bottom fill bar
rsiMfiBarTop    = plot(showMFI ? -95 : na, "MFI Bar TOP",    color=color.new(color.white, 100))
rsiMfiBarBottom = plot(showMFI ? -99 : na, "MFI Bar BOTTOM", color=color.new(color.white, 100))
fill(rsiMfiBarTop, rsiMfiBarBottom, title="MFI Bar Fill", color=showMFI ? color.new(rsiMFIColor, 75) : na)

// WT wave areas
wt2PlotColor = darkMode ? color.new(colorWT2_dark, 20) : color.new(colorWT2, 20)
plot(showWT ? wt1 : na, "WT Wave 1", color=color.new(colorWT1, 0), style=plot.style_area)
plot(showWT ? wt2 : na, "WT Wave 2", color=wt2PlotColor,             style=plot.style_area)

// VWAP (wt1 - wt2, aka Fast WT)
plot(showVWAP ? wtVwap : na, "VWAP (Fast WT)", color=color.new(colorYellow, 45), style=plot.style_area, linewidth=2)

// RSI+MFI area
rsiMFIplot = plot(showMFI ? rsiMFI : na, "RSI+MFI Area", color=rsiMFIColor)
fill(rsiMFIplot, zLine, color=color.new(rsiMFIColor, 40))

// WT Divergence overlay lines
plot(not na(wtFractalTop)      ? wt2[2] : na, title="WT Bear Div",     color=wtBearDivColor,     linewidth=2, offset=-2)
plot(not na(wtFractalBot)      ? wt2[2] : na, title="WT Bull Div",     color=wtBullDivColor,     linewidth=2, offset=-2)
plot(not na(wtFractalTop_add)  ? wt2[2] : na, title="WT Bear Div 2nd", color=wtBearDivColor_add, linewidth=2, offset=-2)
plot(not na(wtFractalBot_add)  ? wt2[2] : na, title="WT Bull Div 2nd", color=wtBullDivColor_add, linewidth=2, offset=-2)

// RSI plot
plot(showRSI ? rsi : na, "RSI", color=rsiColor, linewidth=2)

// RSI Divergence lines
plot(not na(rsiFractalTop) ? rsi[2] : na, title="RSI Bear Div", color=rsiBearDivColor, linewidth=1, offset=-2)
plot(not na(rsiFractalBot) ? rsi[2] : na, title="RSI Bull Div", color=rsiBullDivColor, linewidth=1, offset=-2)

// Stoch K/D plot
stochKplot = plot(showStoch ? stochK : na, "Stoch K", color=color.new(#21baf3, 0), linewidth=2)
stochDplot = plot(showStoch ? stochD : na, "Stoch D", color=color.new(#673ab7, 60), linewidth=1)
stochFillColor = stochK >= stochD ? color.new(#21baf3, 75) : color.new(#673ab7, 60)
fill(stochKplot, stochDplot, title="Stoch KD Fill", color=stochFillColor)

// Stoch Divergence lines
plot(not na(stochFractalTop) ? stochK[2] : na, title="Stoch Bear Div", color=stochBearDivColor, linewidth=1, offset=-2)
plot(not na(stochFractalBot) ? stochK[2] : na, title="Stoch Bull Div", color=stochBullDivColor, linewidth=1, offset=-2)

// Schaff TC
plot(showSchaff ? tcVal : na, title="Schaff TC (inner)", color=color.new(#673ab7, 25), linewidth=2)
plot(showSchaff ? tcVal : na, title="Schaff TC (outer)", color=color.new(colorWhite, 50), linewidth=1)

// OB/OS reference lines
plot(obLevel2, "OB Level 2", color=color.new(colorWhite, 85), linewidth=1, style=plot.style_stepline)
plot(obLevel3, "OB Level 3", color=color.new(colorWhite, 95), linewidth=1, style=plot.style_circles)
plot(osLevel2, "OS Level 2", color=color.new(colorWhite, 85), linewidth=1, style=plot.style_stepline)

// Small WT-cross circle
plot(showSmallCross and wtCross ? wt2 : na, "WT Cross Circle", color=color.new(signalColor, 15), style=plot.style_circles, linewidth=3)

// Buy / Sell big circles + divergence circles
plotchar(showBuyDots  and buySignal      ? -107 : na, "Buy circle",        "·", color=color.new(colorGreen, 50),                          location=location.absolute, size=size.small)
plotchar(showSellDots and sellSignal     ?  105 : na, "Sell circle",       "·", color=color.new(colorRed,   50),                          location=location.absolute, size=size.small)
plotchar(showDivDots  and buySignalDiv   ? -106 : na, "Div buy circle",    "•", color=buySignalDivColor,                                  location=location.absolute, size=size.small, offset=-2)
plotchar(showDivDots  and sellSignalDiv  ?  106 : na, "Div sell circle",   "•", color=sellSignalDivColor,                                 location=location.absolute, size=size.small, offset=-2)
plotchar(showGoldDots and wtGoldBuy      ? -106 : na, "Gold buy circle",   "•", color=color.new(colorOrange, 15),                         location=location.absolute, size=size.small, offset=-2)

// ═══════════════════════════════════════════════════════════════════════════════
// LAST-SIGNAL TRACKING (for the bot table)
// ═══════════════════════════════════════════════════════════════════════════════
var string lastSignal       = "—"
var int    lastSignalBar    = -999
var string lastWTDivergence = "—"
var int    lastWTDivBar     = -999

if wtGoldBuy
    lastSignal    := "GOLD_BUY"
    lastSignalBar := bar_index
else if buySignal and buySignalDiv
    lastSignal    := "BUY_DIV"
    lastSignalBar := bar_index
else if sellSignal and sellSignalDiv
    lastSignal    := "SELL_DIV"
    lastSignalBar := bar_index
else if buySignal
    lastSignal    := "BUY"
    lastSignalBar := bar_index
else if sellSignal
    lastSignal    := "SELL"
    lastSignalBar := bar_index

if wtBullDiv
    lastWTDivergence := "BULL_REG"
    lastWTDivBar     := bar_index
else if wtBullDivHidden_eff and wtShowHiddenDiv
    lastWTDivergence := "BULL_HIDDEN"
    lastWTDivBar     := bar_index
else if wtBearDiv
    lastWTDivergence := "BEAR_REG"
    lastWTDivBar     := bar_index
else if wtBearDivHidden_eff and wtShowHiddenDiv
    lastWTDivergence := "BEAR_HIDDEN"
    lastWTDivBar     := bar_index

// Composite momentum score 0–5 for bot consumption
// 1pt each for: WT bullish, MFI bullish, RSI neutral/bullish, Stoch K > D, last signal was buy within 5 bars
int momentumScore = 0
if wt2 > wt1
    momentumScore += 1
if rsiMFI > 0
    momentumScore += 1
if rsi > 50
    momentumScore += 1
if stochK > stochD
    momentumScore += 1
if (lastSignal == "BUY" or lastSignal == "BUY_DIV" or lastSignal == "GOLD_BUY") and (bar_index - lastSignalBar) <= 5
    momentumScore += 1

// ═══════════════════════════════════════════════════════════════════════════════
// OSCILLATOR TABLE — bot reads via  tv stream tables --filter "SMT Oscillator"
// ═══════════════════════════════════════════════════════════════════════════════
var table oscTable = table.new(position.top_right, 2, 15, bgcolor=color.new(color.black, 75), border_width=1)

if showTable and barstate.islast
    bullCol = color.new(colorGreen, 0)
    bearCol = color.new(colorRed,   0)
    neutCol = color.gray

    wtState = wtOverbought ? "OVERBOUGHT" : wtOversold ? "OVERSOLD" : "NEUTRAL"
    wtCol   = wtOverbought ? bearCol : wtOversold ? bullCol : neutCol

    wtCrossState = wtCross ? (wtCrossUp ? "UP" : "DOWN") : "—"
    wtCrossCol   = wtCrossState == "UP" ? bullCol : wtCrossState == "DOWN" ? bearCol : neutCol

    rsiState = rsi <= rsiOversold ? "OVERSOLD" : rsi >= rsiOverbought ? "OVERBOUGHT" : "NEUTRAL"
    rsiStateCol = rsi <= rsiOversold ? bullCol : rsi >= rsiOverbought ? bearCol : neutCol

    mfiBias = rsiMFI > 0 ? "BULLISH" : rsiMFI < 0 ? "BEARISH" : "NEUTRAL"
    mfiCol  = rsiMFI > 0 ? bullCol : rsiMFI < 0 ? bearCol : neutCol

    stochState = stochK > stochD ? "K>D (bullish)" : "D>K (bearish)"
    stochCol   = stochK > stochD ? bullCol : bearCol

    sigCol = str.contains(lastSignal, "BUY")  or lastSignal == "GOLD_BUY" ? bullCol : str.contains(lastSignal, "SELL") ? bearCol : neutCol
    divCol = str.contains(lastWTDivergence, "BULL") ? bullCol : str.contains(lastWTDivergence, "BEAR") ? bearCol : neutCol

    momCol = momentumScore >= 4 ? bullCol : momentumScore >= 2 ? color.yellow : bearCol

    int row = 0

    table.cell(oscTable, 0, row, "=== SMT Oscillator ===", text_color=color.white, text_size=size.small)
    table.cell(oscTable, 1, row, syminfo.ticker,            text_color=color.white, text_size=size.small)
    row += 1

    table.cell(oscTable, 0, row, "wt1",  text_color=neutCol, text_size=size.small)
    table.cell(oscTable, 1, row, str.tostring(wt1, "#.##"), text_color=color.new(colorWT1, 0), text_size=size.small)
    row += 1

    table.cell(oscTable, 0, row, "wt2",  text_color=neutCol, text_size=size.small)
    table.cell(oscTable, 1, row, str.tostring(wt2, "#.##"), text_color=color.new(colorWT2, 0), text_size=size.small)
    row += 1

    table.cell(oscTable, 0, row, "wt_state", text_color=neutCol, text_size=size.small)
    table.cell(oscTable, 1, row, wtState,    text_color=wtCol,   text_size=size.small)
    row += 1

    table.cell(oscTable, 0, row, "wt_cross",  text_color=neutCol,     text_size=size.small)
    table.cell(oscTable, 1, row, wtCrossState, text_color=wtCrossCol, text_size=size.small)
    row += 1

    table.cell(oscTable, 0, row, "wt_vwap_fast", text_color=neutCol, text_size=size.small)
    vwapCol = wtVwap > 0 ? bullCol : wtVwap < 0 ? bearCol : neutCol
    table.cell(oscTable, 1, row, str.tostring(wtVwap, "#.##"), text_color=vwapCol, text_size=size.small)
    row += 1

    table.cell(oscTable, 0, row, "rsi", text_color=neutCol, text_size=size.small)
    table.cell(oscTable, 1, row, str.tostring(rsi, "#.##") + " (" + rsiState + ")", text_color=rsiStateCol, text_size=size.small)
    row += 1

    table.cell(oscTable, 0, row, "rsi_mfi", text_color=neutCol, text_size=size.small)
    table.cell(oscTable, 1, row, str.tostring(rsiMFI, "#.##") + " (" + mfiBias + ")", text_color=mfiCol, text_size=size.small)
    row += 1

    table.cell(oscTable, 0, row, "stoch_k", text_color=neutCol, text_size=size.small)
    table.cell(oscTable, 1, row, str.tostring(stochK, "#.##"), text_color=color.new(#21baf3, 0), text_size=size.small)
    row += 1

    table.cell(oscTable, 0, row, "stoch_d", text_color=neutCol, text_size=size.small)
    table.cell(oscTable, 1, row, str.tostring(stochD, "#.##"), text_color=color.new(#673ab7, 0), text_size=size.small)
    row += 1

    table.cell(oscTable, 0, row, "stoch_state", text_color=neutCol, text_size=size.small)
    table.cell(oscTable, 1, row, stochState, text_color=stochCol, text_size=size.small)
    row += 1

    table.cell(oscTable, 0, row, "last_signal", text_color=neutCol, text_size=size.small)
    sigAge = bar_index - lastSignalBar
    sigStr = lastSignal == "—" ? "—" : lastSignal + " (" + str.tostring(sigAge) + "b ago)"
    table.cell(oscTable, 1, row, sigStr, text_color=sigCol, text_size=size.small)
    row += 1

    table.cell(oscTable, 0, row, "last_wt_div", text_color=neutCol, text_size=size.small)
    divAge = bar_index - lastWTDivBar
    divStr = lastWTDivergence == "—" ? "—" : lastWTDivergence + " (" + str.tostring(divAge) + "b ago)"
    table.cell(oscTable, 1, row, divStr, text_color=divCol, text_size=size.small)
    row += 1

    table.cell(oscTable, 0, row, "momentum", text_color=neutCol, text_size=size.small)
    table.cell(oscTable, 1, row, str.tostring(momentumScore) + "/5", text_color=momCol, text_size=size.small)
    row += 1

    table.cell(oscTable, 0, row, "last_bar", text_color=neutCol, text_size=size.small)
    table.cell(oscTable, 1, row, str.tostring(bar_index), text_color=color.white, text_size=size.small)

// ═══════════════════════════════════════════════════════════════════════════════
// ALERTS
// ═══════════════════════════════════════════════════════════════════════════════
alertcondition(buySignal,            "Buy (Big Green Circle)",           "WT oversold + bullish cross")
alertcondition(sellSignal,           "Sell (Big Red Circle)",            "WT overbought + bearish cross")
alertcondition(buySignalDiv,         "Buy + Divergence",                 "Bullish divergence (WT/RSI/Stoch)")
alertcondition(sellSignalDiv,        "Sell + Divergence",                "Bearish divergence (WT/RSI/Stoch)")
alertcondition(wtGoldBuy,            "GOLD BUY (rare high-prob)",        "Gold buy signal")
alertcondition(wtCross and wtCrossUp,   "WT Cross UP (small green)",     "WaveTrend bullish cross")
alertcondition(wtCross and wtCrossDown, "WT Cross DOWN (small red)",     "WaveTrend bearish cross")
alertcondition(wtBullDiv,            "WT Bullish Regular Divergence",    "WT bullish regular divergence")
alertcondition(wtBearDiv,            "WT Bearish Regular Divergence",    "WT bearish regular divergence")
alertcondition(wtBullDivHidden_eff,  "WT Bullish Hidden Divergence",     "WT bullish hidden divergence")
alertcondition(wtBearDivHidden_eff,  "WT Bearish Hidden Divergence",     "WT bearish hidden divergence")
