//@version=6
indicator("FVG Mapper", overlay=true, max_boxes_count=500, max_labels_count=500)

// ─── INPUTS ───────────────────────────────────────────────────────────────────
showBullFVG    = input.bool(true, "Show Bullish FVGs")
showBearFVG    = input.bool(true, "Show Bearish FVGs")
showMitigated  = input.bool(false, "Show Mitigated FVGs", tooltip="Keep mitigated (filled) FVGs visible with reduced opacity")
maxFVGAge      = input.int(100, "Max FVG Age (bars)", minval=10, maxval=500, tooltip="Remove FVGs older than this many bars")
minFVGSize     = input.float(0.0, "Min FVG Size (%)", minval=0.0, step=0.05, tooltip="Minimum gap size as percentage of price. 0 = no filter")
extendFVG      = input.bool(true, "Extend FVG Boxes Right", tooltip="Extend active FVG boxes to current bar")

bullFVGColor   = input.color(color.new(#00C853, 75), "Bullish FVG Color")
bearFVGColor   = input.color(color.new(#FF1744, 75), "Bearish FVG Color")
mitigatedAlpha = input.int(90, "Mitigated Opacity", minval=50, maxval=95)

// ─── FVG DATA STORAGE ────────────────────────────────────────────────────────
// Using arrays to track active FVGs for mitigation checking
var array<box>    fvgBoxes      = array.new<box>()
var array<float>  fvgTops       = array.new<float>()
var array<float>  fvgBottoms    = array.new<float>()
var array<int>    fvgDirs       = array.new<int>()      // 1 = bull, -1 = bear
var array<int>    fvgBars       = array.new<int>()       // creation bar
var array<bool>   fvgMitigated  = array.new<bool>()
var array<label>  fvgLabels     = array.new<label>()

// ─── FVG DETECTION ───────────────────────────────────────────────────────────
// Bullish FVG: 3-candle pattern where candle 1's high < candle 3's low
//   Gap zone = [candle1_high, candle3_low]
//   Candle 2 is the impulse candle
//
// Bearish FVG: 3-candle pattern where candle 1's low > candle 3's high
//   Gap zone = [candle3_high, candle1_low]

// Reference bars: [2] = candle 1, [1] = candle 2 (impulse), [0] = candle 3
c1_high = high[2]
c1_low  = low[2]
c3_high = high[0]
c3_low  = low[0]

// Bullish FVG: gap between candle 1 high and candle 3 low
isBullFVG = c3_low > c1_high
bullGapTop = c3_low
bullGapBot = c1_high
bullGapPct = isBullFVG ? ((bullGapTop - bullGapBot) / bullGapBot) * 100 : 0.0

// Bearish FVG: gap between candle 3 high and candle 1 low
isBearFVG = c1_low > c3_high
bearGapTop = c1_low
bearGapBot = c3_high
bearGapPct = isBearFVG ? ((bearGapTop - bearGapBot) / bearGapBot) * 100 : 0.0

// ─── CREATE BULLISH FVG ──────────────────────────────────────────────────────
if isBullFVG and showBullFVG and bullGapPct >= minFVGSize
    fvgBox = box.new(
         bar_index - 2, bullGapTop,
         bar_index, bullGapBot,
         border_color = bullFVGColor,
         bgcolor      = bullFVGColor,
         border_width = 1
         )

    // Structured tooltip for bot parsing
    tooltipText = "FVG|BULLISH|" + str.tostring(bullGapBot, "#.##") + "|" + str.tostring(bullGapTop, "#.##") + "|" + str.tostring(bullGapPct, "#.##") + "%|ACTIVE"

    fvgLbl = label.new(
         bar_index - 1, bullGapBot,
         "",
         style     = label.style_none,
         tooltip   = tooltipText,
         size      = size.tiny
         )

    array.push(fvgBoxes, fvgBox)
    array.push(fvgTops, bullGapTop)
    array.push(fvgBottoms, bullGapBot)
    array.push(fvgDirs, 1)
    array.push(fvgBars, bar_index)
    array.push(fvgMitigated, false)
    array.push(fvgLabels, fvgLbl)

// ─── CREATE BEARISH FVG ──────────────────────────────────────────────────────
if isBearFVG and showBearFVG and bearGapPct >= minFVGSize
    fvgBox = box.new(
         bar_index - 2, bearGapTop,
         bar_index, bearGapBot,
         border_color = bearFVGColor,
         bgcolor      = bearFVGColor,
         border_width = 1
         )

    tooltipText = "FVG|BEARISH|" + str.tostring(bearGapBot, "#.##") + "|" + str.tostring(bearGapTop, "#.##") + "|" + str.tostring(bearGapPct, "#.##") + "%|ACTIVE"

    fvgLbl = label.new(
         bar_index - 1, bearGapTop,
         "",
         style     = label.style_none,
         tooltip   = tooltipText,
         size      = size.tiny
         )

    array.push(fvgBoxes, fvgBox)
    array.push(fvgTops, bearGapTop)
    array.push(fvgBottoms, bearGapBot)
    array.push(fvgDirs, -1)
    array.push(fvgBars, bar_index)
    array.push(fvgMitigated, false)
    array.push(fvgLabels, fvgLbl)

// ─── MITIGATION CHECK & CLEANUP ──────────────────────────────────────────────
// An FVG is mitigated (filled) when price fully trades through the gap zone:
//   - Bullish FVG mitigated when low <= gap bottom (price retraced into the gap)
//   - Bearish FVG mitigated when high >= gap top (price retraced into the gap)
//
// We iterate backwards so removing elements doesn't shift unprocessed indices.

if array.size(fvgBoxes) > 0
    for i = array.size(fvgBoxes) - 1 to 0
        fvgTop    = array.get(fvgTops, i)
        fvgBot    = array.get(fvgBottoms, i)
        fvgDir    = array.get(fvgDirs, i)
        fvgBar    = array.get(fvgBars, i)
        mitigated = array.get(fvgMitigated, i)
        bx        = array.get(fvgBoxes, i)
        lbl       = array.get(fvgLabels, i)

        // Check age — remove old FVGs
        age = bar_index - fvgBar
        if age > maxFVGAge
            box.delete(bx)
            label.delete(lbl)
            array.remove(fvgBoxes, i)
            array.remove(fvgTops, i)
            array.remove(fvgBottoms, i)
            array.remove(fvgDirs, i)
            array.remove(fvgBars, i)
            array.remove(fvgMitigated, i)
            array.remove(fvgLabels, i)
            continue

        // Check mitigation
        if not mitigated
            isMitigatedNow = false

            if fvgDir == 1  // bullish FVG: mitigated when price drops into gap
                isMitigatedNow := low <= fvgBot
            else  // bearish FVG: mitigated when price rises into gap
                isMitigatedNow := high >= fvgTop

            if isMitigatedNow
                array.set(fvgMitigated, i, true)

                if showMitigated
                    // Dim the box
                    origColor = fvgDir == 1 ? bullFVGColor : bearFVGColor
                    dimColor  = color.new(origColor, mitigatedAlpha)
                    box.set_bgcolor(bx, dimColor)
                    box.set_border_color(bx, dimColor)

                    // Update tooltip
                    newTooltip = "FVG|" + (fvgDir == 1 ? "BULLISH" : "BEARISH") + "|" + str.tostring(fvgBot, "#.##") + "|" + str.tostring(fvgTop, "#.##") + "|MITIGATED"
                    label.set_tooltip(lbl, newTooltip)
                else
                    // Remove mitigated FVGs entirely
                    box.delete(bx)
                    label.delete(lbl)
                    array.remove(fvgBoxes, i)
                    array.remove(fvgTops, i)
                    array.remove(fvgBottoms, i)
                    array.remove(fvgDirs, i)
                    array.remove(fvgBars, i)
                    array.remove(fvgMitigated, i)
                    array.remove(fvgLabels, i)
                    continue

        // Extend active FVGs to current bar
        if extendFVG and not (array.get(fvgMitigated, i))
            box.set_right(bx, bar_index)

// ─── STATISTICS TABLE ────────────────────────────────────────────────────────
// Display FVG counts for bot to read via `tv stream tables --filter "FVG"`
var table statsTable = table.new(position.bottom_right, 2, 5, bgcolor=color.new(color.black, 80), border_width=1)

if barstate.islast
    activeBull = 0
    activeBear = 0
    mitigatedCount = 0

    if array.size(fvgDirs) > 0
        for i = 0 to array.size(fvgDirs) - 1
            if array.get(fvgMitigated, i)
                mitigatedCount += 1
            else if array.get(fvgDirs, i) == 1
                activeBull += 1
            else
                activeBear += 1

    // Find nearest active bullish and bearish FVG to current price
    nearestBullFVG = ""
    nearestBearFVG = ""
    nearestBullDist = 999999999.0
    nearestBearDist = 999999999.0

    if array.size(fvgDirs) > 0
        for i = 0 to array.size(fvgDirs) - 1
            if not array.get(fvgMitigated, i)
                fvgMid = (array.get(fvgTops, i) + array.get(fvgBottoms, i)) / 2
                dist = math.abs(close - fvgMid)

                if array.get(fvgDirs, i) == 1 and dist < nearestBullDist
                    nearestBullDist := dist
                    nearestBullFVG := str.tostring(array.get(fvgBottoms, i), "#.##") + "-" + str.tostring(array.get(fvgTops, i), "#.##")

                if array.get(fvgDirs, i) == -1 and dist < nearestBearDist
                    nearestBearDist := dist
                    nearestBearFVG := str.tostring(array.get(fvgBottoms, i), "#.##") + "-" + str.tostring(array.get(fvgTops, i), "#.##")

    table.cell(statsTable, 0, 0, "FVG Mapper",         text_color=color.white, text_size=size.small)
    table.cell(statsTable, 1, 0, "",                    text_color=color.white, text_size=size.small)

    table.cell(statsTable, 0, 1, "Bull FVGs",           text_color=color.gray,  text_size=size.small)
    table.cell(statsTable, 1, 1, str.tostring(activeBull), text_color=bullFVGColor, text_size=size.small)

    table.cell(statsTable, 0, 2, "Bear FVGs",           text_color=color.gray,  text_size=size.small)
    table.cell(statsTable, 1, 2, str.tostring(activeBear), text_color=bearFVGColor, text_size=size.small)

    table.cell(statsTable, 0, 3, "Nearest Bull",        text_color=color.gray,  text_size=size.small)
    table.cell(statsTable, 1, 3, nearestBullFVG == "" ? "—" : nearestBullFVG, text_color=bullFVGColor, text_size=size.small)

    table.cell(statsTable, 0, 4, "Nearest Bear",        text_color=color.gray,  text_size=size.small)
    table.cell(statsTable, 1, 4, nearestBearFVG == "" ? "—" : nearestBearFVG, text_color=bearFVGColor, text_size=size.small)
