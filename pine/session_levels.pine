//@version=6
indicator("Session Levels", overlay=true, max_lines_count=500, max_labels_count=200, max_boxes_count=100)

// ─── INPUTS ───────────────────────────────────────────────────────────────────
showAsian   = input.bool(true, "Show Asian Session",  group="Sessions")
showLondon  = input.bool(true, "Show London Session", group="Sessions")
showNY      = input.bool(true, "Show New York Session", group="Sessions")

asianStart  = input.session("2000-0000", "Asian Session",  group="Session Times")
londonStart = input.session("0700-1600", "London Session", group="Session Times")
nyStart     = input.session("1200-2100", "New York Session", group="Session Times")

showPrevDay = input.bool(true, "Show Previous Day H/L", group="Daily Levels")
showWeekHL  = input.bool(true, "Show Previous Week H/L", group="Weekly Levels")

asianColor  = input.color(color.new(#9C27B0, 60), "Asian Color",  group="Colors")
londonColor = input.color(color.new(#2196F3, 60), "London Color", group="Colors")
nyColor     = input.color(color.new(#FF9800, 60), "NY Color",     group="Colors")
pdColor     = input.color(color.new(#FFFFFF, 40), "Prev Day Color", group="Colors")
pwColor     = input.color(color.new(#FFD700, 40), "Prev Week Color", group="Colors")

extendLines = input.bool(true, "Extend Session Lines Right")

// ─── SESSION DETECTION ────────────────────────────────────────────────────────
isAsian  = not na(time(timeframe.period, asianStart, "UTC"))
isLondon = not na(time(timeframe.period, londonStart, "UTC"))
isNY     = not na(time(timeframe.period, nyStart, "UTC"))

// ─── SESSION HIGH/LOW TRACKING ────────────────────────────────────────────────
var float asianHigh  = na
var float asianLow   = na
var bool  asianActive = false
var int   asianStartBar = na

var float londonHigh = na
var float londonLow  = na
var bool  londonActive = false
var int   londonStartBar = na

var float nyHigh     = na
var float nyLow      = na
var bool  nyActive   = false
var int   nyStartBar = na

// Session H/L lines (persistent)
var line asianHighLine  = na
var line asianLowLine   = na
var line londonHighLine = na
var line londonLowLine  = na
var line nyHighLine     = na
var line nyLowLine      = na

// ─── ASIAN SESSION ────────────────────────────────────────────────────────────
if isAsian
    if not asianActive
        // Session just started
        asianActive   := true
        asianHigh     := high
        asianLow      := low
        asianStartBar := bar_index

        // Delete old lines
        line.delete(asianHighLine)
        line.delete(asianLowLine)
    else
        asianHigh := math.max(asianHigh, high)
        asianLow  := math.min(asianLow, low)
else
    if asianActive
        asianActive := false
        // Draw session H/L lines
        if showAsian and not na(asianHigh)
            asianHighLine := line.new(asianStartBar, asianHigh, bar_index, asianHigh, color=asianColor, style=line.style_solid, width=2)
            asianLowLine  := line.new(asianStartBar, asianLow, bar_index, asianLow, color=asianColor, style=line.style_solid, width=2)

// ─── LONDON SESSION ───────────────────────────────────────────────────────────
if isLondon
    if not londonActive
        londonActive   := true
        londonHigh     := high
        londonLow      := low
        londonStartBar := bar_index
        line.delete(londonHighLine)
        line.delete(londonLowLine)
    else
        londonHigh := math.max(londonHigh, high)
        londonLow  := math.min(londonLow, low)
else
    if londonActive
        londonActive := false
        if showLondon and not na(londonHigh)
            londonHighLine := line.new(londonStartBar, londonHigh, bar_index, londonHigh, color=londonColor, style=line.style_solid, width=2)
            londonLowLine  := line.new(londonStartBar, londonLow, bar_index, londonLow, color=londonColor, style=line.style_solid, width=2)

// ─── NEW YORK SESSION ─────────────────────────────────────────────────────────
if isNY
    if not nyActive
        nyActive   := true
        nyHigh     := high
        nyLow      := low
        nyStartBar := bar_index
        line.delete(nyHighLine)
        line.delete(nyLowLine)
    else
        nyHigh := math.max(nyHigh, high)
        nyLow  := math.min(nyLow, low)
else
    if nyActive
        nyActive := false
        if showNY and not na(nyHigh)
            nyHighLine := line.new(nyStartBar, nyHigh, bar_index, nyHigh, color=nyColor, style=line.style_solid, width=2)
            nyLowLine  := line.new(nyStartBar, nyLow, bar_index, nyLow, color=nyColor, style=line.style_solid, width=2)

// ─── EXTEND LINES ─────────────────────────────────────────────────────────────
if extendLines
    if not na(asianHighLine)
        line.set_x2(asianHighLine, bar_index)
        line.set_x2(asianLowLine, bar_index)
    if not na(londonHighLine)
        line.set_x2(londonHighLine, bar_index)
        line.set_x2(londonLowLine, bar_index)
    if not na(nyHighLine)
        line.set_x2(nyHighLine, bar_index)
        line.set_x2(nyLowLine, bar_index)

// ─── PREVIOUS DAY HIGH/LOW ───────────────────────────────────────────────────
prevDayHigh = request.security(syminfo.tickerid, "D", high[1], lookahead=barmerge.lookahead_on)
prevDayLow  = request.security(syminfo.tickerid, "D", low[1], lookahead=barmerge.lookahead_on)

var line pdHighLine = na
var line pdLowLine  = na

if showPrevDay and barstate.islast
    line.delete(pdHighLine)
    line.delete(pdLowLine)

    if not na(prevDayHigh)
        pdHighLine := line.new(bar_index - 50, prevDayHigh, bar_index, prevDayHigh, color=pdColor, style=line.style_dashed, width=1)
        pdLowLine  := line.new(bar_index - 50, prevDayLow, bar_index, prevDayLow, color=pdColor, style=line.style_dashed, width=1)

        label.new(bar_index, prevDayHigh, "PDH", style=label.style_none, textcolor=pdColor, size=size.tiny)
        label.new(bar_index, prevDayLow, "PDL", style=label.style_none, textcolor=pdColor, size=size.tiny)

// ─── PREVIOUS WEEK HIGH/LOW ──────────────────────────────────────────────────
prevWeekHigh = request.security(syminfo.tickerid, "W", high[1], lookahead=barmerge.lookahead_on)
prevWeekLow  = request.security(syminfo.tickerid, "W", low[1], lookahead=barmerge.lookahead_on)

var line pwHighLine = na
var line pwLowLine  = na

if showWeekHL and barstate.islast
    line.delete(pwHighLine)
    line.delete(pwLowLine)

    if not na(prevWeekHigh)
        pwHighLine := line.new(bar_index - 100, prevWeekHigh, bar_index, prevWeekHigh, color=pwColor, style=line.style_dashed, width=2)
        pwLowLine  := line.new(bar_index - 100, prevWeekLow, bar_index, prevWeekLow, color=pwColor, style=line.style_dashed, width=2)

        label.new(bar_index, prevWeekHigh, "PWH", style=label.style_none, textcolor=pwColor, size=size.tiny)
        label.new(bar_index, prevWeekLow, "PWL", style=label.style_none, textcolor=pwColor, size=size.tiny)

// ─── INFO TABLE ──────────────────────────────────────────────────────────────
var table infoTable = table.new(position.top_left, 2, 9, bgcolor=color.new(color.black, 80), border_width=1)

if barstate.islast
    // Determine active session
    activeSession = isAsian ? "ASIAN" : isLondon ? "LONDON" : isNY ? "NEW YORK" : "OFF"
    sessionCol = isAsian ? asianColor : isLondon ? londonColor : isNY ? nyColor : color.gray

    table.cell(infoTable, 0, 0, "Session Levels",      text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 0, "",                     text_color=color.white, text_size=size.small)

    table.cell(infoTable, 0, 1, "Active",               text_color=color.gray,  text_size=size.small)
    table.cell(infoTable, 1, 1, activeSession,          text_color=sessionCol,  text_size=size.small)

    table.cell(infoTable, 0, 2, "Asian H/L",            text_color=color.gray,  text_size=size.small)
    table.cell(infoTable, 1, 2, (na(asianHigh) ? "—" : str.tostring(asianHigh, "#.##") + "/" + str.tostring(asianLow, "#.##")),
               text_color=asianColor, text_size=size.small)

    table.cell(infoTable, 0, 3, "London H/L",           text_color=color.gray,  text_size=size.small)
    table.cell(infoTable, 1, 3, (na(londonHigh) ? "—" : str.tostring(londonHigh, "#.##") + "/" + str.tostring(londonLow, "#.##")),
               text_color=londonColor, text_size=size.small)

    table.cell(infoTable, 0, 4, "NY H/L",               text_color=color.gray,  text_size=size.small)
    table.cell(infoTable, 1, 4, (na(nyHigh) ? "—" : str.tostring(nyHigh, "#.##") + "/" + str.tostring(nyLow, "#.##")),
               text_color=nyColor, text_size=size.small)

    table.cell(infoTable, 0, 5, "PDH",                  text_color=color.gray,  text_size=size.small)
    table.cell(infoTable, 1, 5, na(prevDayHigh) ? "—" : str.tostring(prevDayHigh, "#.##"),
               text_color=pdColor, text_size=size.small)

    table.cell(infoTable, 0, 6, "PDL",                  text_color=color.gray,  text_size=size.small)
    table.cell(infoTable, 1, 6, na(prevDayLow) ? "—" : str.tostring(prevDayLow, "#.##"),
               text_color=pdColor, text_size=size.small)

    table.cell(infoTable, 0, 7, "PWH",                  text_color=color.gray,  text_size=size.small)
    table.cell(infoTable, 1, 7, na(prevWeekHigh) ? "—" : str.tostring(prevWeekHigh, "#.##"),
               text_color=pwColor, text_size=size.small)

    table.cell(infoTable, 0, 8, "PWL",                  text_color=color.gray,  text_size=size.small)
    table.cell(infoTable, 1, 8, na(prevWeekLow) ? "—" : str.tostring(prevWeekLow, "#.##"),
               text_color=pwColor, text_size=size.small)
