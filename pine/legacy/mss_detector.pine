//@version=6
indicator("MSS Detector", overlay=true, max_labels_count=500, max_lines_count=500)

// ─── INPUTS ───────────────────────────────────────────────────────────────────
swingLen       = input.int(5, "Swing Lookback", minval=2, maxval=50, tooltip="Number of bars left/right to confirm a swing point")
showLabels     = input.bool(true, "Show Swing Labels (HH/HL/LH/LL)")
showMSS        = input.bool(true, "Show MSS Signals")
showStructure  = input.bool(true, "Show Structure Lines")
bullColor      = input.color(color.new(#00C853, 0), "Bullish Color")
bearColor      = input.color(color.new(#FF1744, 0), "Bearish Color")
mssLabelSize   = input.string("normal", "MSS Label Size", options=["tiny", "small", "normal", "large"])

// ─── SWING DETECTION ──────────────────────────────────────────────────────────
// Detect swing highs and swing lows using ta.pivothigh / ta.pivotlow
swingHigh = ta.pivothigh(high, swingLen, swingLen)
swingLow  = ta.pivotlow(low, swingLen, swingLen)

// ─── STATE TRACKING ──────────────────────────────────────────────────────────
// Track the last two swing highs and swing lows to determine structure
var float lastSH     = na   // last swing high price
var int   lastSHBar  = na   // bar index of last swing high
var float prevSH     = na   // previous swing high price
var int   prevSHBar  = na   // bar index of previous swing high

var float lastSL     = na   // last swing low price
var int   lastSLBar  = na   // bar index of last swing low
var float prevSL     = na   // previous swing low price
var int   prevSLBar  = na   // bar index of previous swing low

// Structure classification for current swing point
var string lastHType = na   // "HH" or "LH"
var string lastLType = na   // "HL" or "LL"

// Trend state: 1 = bullish, -1 = bearish, 0 = undefined
var int trend = 0

// ─── MSS LABEL SIZE RESOLVER ─────────────────────────────────────────────────
labelSize = switch mssLabelSize
    "tiny"   => size.tiny
    "small"  => size.small
    "large"  => size.large
    => size.normal

// ─── PROCESS SWING HIGHS ─────────────────────────────────────────────────────
if not na(swingHigh)
    swingBar = bar_index - swingLen  // pivot confirmed swingLen bars ago

    // Classify: Higher High or Lower High
    string hType = na
    if not na(lastSH)
        hType := swingHigh > lastSH ? "HH" : "LH"

    // Update history
    prevSH    := lastSH
    prevSHBar := lastSHBar
    lastSH    := swingHigh
    lastSHBar := swingBar
    lastHType := hType

    // Draw swing high label
    if showLabels and not na(hType)
        lbl = label.new(
             swingBar, swingHigh,
             hType,
             style    = label.style_label_down,
             color    = hType == "HH" ? bullColor : bearColor,
             textcolor= color.white,
             size     = size.tiny
             )

    // Draw structure line connecting previous SH to current SH
    if showStructure and not na(prevSH)
        line.new(
             prevSHBar, prevSH,
             swingBar, swingHigh,
             color = hType == "HH" ? bullColor : bearColor,
             style = line.style_dashed,
             width = 1
             )

// ─── PROCESS SWING LOWS ──────────────────────────────────────────────────────
if not na(swingLow)
    swingBar = bar_index - swingLen

    // Classify: Higher Low or Lower Low
    string lType = na
    if not na(lastSL)
        lType := swingLow > lastSL ? "HL" : "LL"

    // Update history
    prevSL    := lastSL
    prevSLBar := lastSLBar
    lastSL    := swingLow
    lastSLBar := swingBar
    lastLType := lType

    // Draw swing low label
    if showLabels and not na(lType)
        lbl = label.new(
             swingBar, swingLow,
             lType,
             style    = label.style_label_up,
             color    = lType == "HL" ? bullColor : bearColor,
             textcolor= color.white,
             size     = size.tiny
             )

    // Draw structure line connecting previous SL to current SL
    if showStructure and not na(prevSL)
        line.new(
             prevSLBar, prevSL,
             swingBar, swingLow,
             color = lType == "HL" ? bullColor : bearColor,
             style = line.style_dashed,
             width = 1
             )

// ─── MSS DETECTION ───────────────────────────────────────────────────────────
// MSS (Market Structure Shift) = trend reversal signal
//
// Bullish MSS: trend was bearish (LH + LL sequence), then we get a HH
//   → bearish structure broken, potential reversal to upside
//
// Bearish MSS: trend was bullish (HH + HL sequence), then we get a LL
//   → bullish structure broken, potential reversal to downside

var int   lastMSSBar   = 0    // prevent duplicate MSS on same bar
var float lastMSSPrice = na

// Detect bullish MSS: was bearish, now swing high makes HH
if not na(swingHigh) and lastHType == "HH" and trend == -1
    swingBar = bar_index - swingLen
    if swingBar != lastMSSBar
        trend       := 1
        lastMSSBar  := swingBar
        lastMSSPrice := swingHigh

        if showMSS
            // Structured output label for bot parsing:
            // Format: MSS|DIRECTION|PRICE|BAR_INDEX
            structuredText = "MSS|BULLISH|" + str.tostring(swingHigh, "#.##") + "|" + str.tostring(swingBar)

            label.new(
                 swingBar, swingHigh,
                 "MSS ▲\nBULLISH",
                 style     = label.style_label_down,
                 color     = bullColor,
                 textcolor = color.white,
                 size      = labelSize,
                 tooltip   = structuredText
                 )

// Detect bearish MSS: was bullish, now swing low makes LL
if not na(swingLow) and lastLType == "LL" and trend == 1
    swingBar = bar_index - swingLen
    if swingBar != lastMSSBar
        trend       := -1
        lastMSSBar  := swingBar
        lastMSSPrice := swingLow

        if showMSS
            structuredText = "MSS|BEARISH|" + str.tostring(swingLow, "#.##") + "|" + str.tostring(swingBar)

            label.new(
                 swingBar, swingLow,
                 "MSS ▼\nBEARISH",
                 style     = label.style_label_up,
                 color     = bearColor,
                 textcolor = color.white,
                 size      = labelSize,
                 tooltip   = structuredText
                 )

// ─── INITIAL TREND DETECTION ─────────────────────────────────────────────────
// Set initial trend based on first two swing classifications
if trend == 0
    if lastHType == "HH" and lastLType == "HL"
        trend := 1
    else if lastHType == "LH" and lastLType == "LL"
        trend := -1

// ─── BOS (Break of Structure) DETECTION ──────────────────────────────────────
// BOS = trend continuation signal (not reversal like MSS)
//
// Bullish BOS: trend is bullish, new HH confirms continuation
// Bearish BOS: trend is bearish, new LL confirms continuation

var int lastBOSBar = 0

// Bullish BOS
if not na(swingHigh) and lastHType == "HH" and trend == 1
    swingBar = bar_index - swingLen
    if swingBar != lastBOSBar and swingBar != lastMSSBar
        lastBOSBar := swingBar
        if showMSS
            structuredText = "BOS|BULLISH|" + str.tostring(swingHigh, "#.##") + "|" + str.tostring(swingBar)
            label.new(
                 swingBar, swingHigh,
                 "BOS ▲",
                 style     = label.style_label_down,
                 color     = color.new(bullColor, 50),
                 textcolor = color.white,
                 size      = size.tiny,
                 tooltip   = structuredText
                 )

// Bearish BOS
if not na(swingLow) and lastLType == "LL" and trend == -1
    swingBar = bar_index - swingLen
    if swingBar != lastBOSBar and swingBar != lastMSSBar
        lastBOSBar := swingBar
        if showMSS
            structuredText = "BOS|BEARISH|" + str.tostring(swingLow, "#.##") + "|" + str.tostring(swingBar)
            label.new(
                 swingBar, swingLow,
                 "BOS ▼",
                 style     = label.style_label_up,
                 color     = color.new(bearColor, 50),
                 textcolor = color.white,
                 size      = size.tiny,
                 tooltip   = structuredText
                 )

// ─── INFO TABLE ──────────────────────────────────────────────────────────────
// Display current market structure state in a table for bot to read via
// `tv stream tables --filter "MSS"`
var table infoTable = table.new(position.top_right, 2, 6, bgcolor=color.new(color.black, 80), border_width=1)

if barstate.islast
    trendStr = trend == 1 ? "BULLISH" : trend == -1 ? "BEARISH" : "UNDEFINED"
    trendCol = trend == 1 ? bullColor : trend == -1 ? bearColor : color.gray

    table.cell(infoTable, 0, 0, "MSS Detector",    text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 0, "",                 text_color=color.white, text_size=size.small)

    table.cell(infoTable, 0, 1, "Trend",            text_color=color.gray,  text_size=size.small)
    table.cell(infoTable, 1, 1, trendStr,           text_color=trendCol,    text_size=size.small)

    table.cell(infoTable, 0, 2, "Last SH",          text_color=color.gray,  text_size=size.small)
    table.cell(infoTable, 1, 2, (na(lastSH) ? "—" : str.tostring(lastSH, "#.##")) + " (" + (na(lastHType) ? "—" : lastHType) + ")",
               text_color=color.white, text_size=size.small)

    table.cell(infoTable, 0, 3, "Last SL",          text_color=color.gray,  text_size=size.small)
    table.cell(infoTable, 1, 3, (na(lastSL) ? "—" : str.tostring(lastSL, "#.##")) + " (" + (na(lastLType) ? "—" : lastLType) + ")",
               text_color=color.white, text_size=size.small)

    table.cell(infoTable, 0, 4, "Last MSS",         text_color=color.gray,  text_size=size.small)
    table.cell(infoTable, 1, 4, na(lastMSSPrice) ? "—" : (trend == 1 ? "BULLISH@" : "BEARISH@") + str.tostring(lastMSSPrice, "#.##"),
               text_color=na(lastMSSPrice) ? color.gray : trendCol, text_size=size.small)

    table.cell(infoTable, 0, 5, "Swing Len",        text_color=color.gray,  text_size=size.small)
    table.cell(infoTable, 1, 5, str.tostring(swingLen), text_color=color.white, text_size=size.small)
