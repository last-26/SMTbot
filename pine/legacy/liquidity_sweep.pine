//@version=6
indicator("Liquidity Sweep Detector", overlay=true, max_labels_count=500, max_lines_count=500)

// ─── INPUTS ───────────────────────────────────────────────────────────────────
eqThreshold    = input.float(0.05, "Equal Level Threshold (%)", minval=0.01, maxval=0.5, step=0.01, tooltip="Max difference between highs/lows to consider them 'equal' (liquidity pool)")
swingLen       = input.int(5, "Swing Lookback", minval=2, maxval=50)
minTouches     = input.int(2, "Min Touches for Liquidity", minval=2, maxval=5, tooltip="Minimum number of equal highs/lows to form a liquidity pool")
sweepWickPct   = input.float(0.1, "Min Sweep Wick (%)", minval=0.01, step=0.01, tooltip="Minimum wick beyond the liquidity level to confirm a sweep")
maxPoolAge     = input.int(300, "Max Pool Age (bars)", minval=50, maxval=1000)
showPools      = input.bool(true, "Show Liquidity Pools")
showSweeps     = input.bool(true, "Show Sweep Events")

bullColor      = input.color(color.new(#00C853, 0), "Bullish Sweep Color")
bearColor      = input.color(color.new(#FF1744, 0), "Bearish Sweep Color")
poolColor      = input.color(color.new(#FFC107, 40), "Liquidity Pool Color")

// ─── SWING DETECTION ──────────────────────────────────────────────────────────
swingHigh = ta.pivothigh(high, swingLen, swingLen)
swingLow  = ta.pivotlow(low, swingLen, swingLen)

// ─── LIQUIDITY POOL TRACKING ─────────────────────────────────────────────────
// Track swing highs and lows to find "equal" levels (liquidity pools)
// Equal highs = sell-side liquidity (stops above)
// Equal lows  = buy-side liquidity (stops below)

var array<float> eqHighLevels   = array.new<float>()   // price level
var array<int>   eqHighTouches  = array.new<int>()      // touch count
var array<int>   eqHighBars     = array.new<int>()      // last touch bar
var array<int>   eqHighFirstBar = array.new<int>()      // first touch bar
var array<bool>  eqHighSwept    = array.new<bool>()
var array<line>  eqHighLines    = array.new<line>()

var array<float> eqLowLevels    = array.new<float>()
var array<int>   eqLowTouches   = array.new<int>()
var array<int>   eqLowBars      = array.new<int>()
var array<int>   eqLowFirstBar  = array.new<int>()
var array<bool>  eqLowSwept     = array.new<bool>()
var array<line>  eqLowLines     = array.new<line>()

// ─── PROCESS SWING HIGHS → EQUAL HIGHS ───────────────────────────────────────
if not na(swingHigh)
    swingBar = bar_index - swingLen
    matched = false

    // Check if this swing high matches an existing equal high level
    if array.size(eqHighLevels) > 0
        for i = 0 to array.size(eqHighLevels) - 1
            if not array.get(eqHighSwept, i)
                level = array.get(eqHighLevels, i)
                diff = math.abs(swingHigh - level) / level * 100

                if diff <= eqThreshold
                    // Match! Increment touch count, update level to average
                    touches = array.get(eqHighTouches, i) + 1
                    array.set(eqHighTouches, i, touches)
                    array.set(eqHighBars, i, swingBar)
                    // Update level to average of all touches
                    newLevel = (level * (touches - 1) + swingHigh) / touches
                    array.set(eqHighLevels, i, newLevel)

                    // Update or create line
                    if showPools
                        oldLine = array.get(eqHighLines, i)
                        line.delete(oldLine)
                        firstBar = array.get(eqHighFirstBar, i)
                        newLine = line.new(
                             firstBar, newLevel,
                             bar_index, newLevel,
                             color = poolColor,
                             style = line.style_dashed,
                             width = touches >= minTouches ? 2 : 1
                             )
                        array.set(eqHighLines, i, newLine)

                    matched := true
                    break

    if not matched
        // New level
        array.push(eqHighLevels, swingHigh)
        array.push(eqHighTouches, 1)
        array.push(eqHighBars, swingBar)
        array.push(eqHighFirstBar, swingBar)
        array.push(eqHighSwept, false)

        ln = showPools ? line.new(swingBar, swingHigh, bar_index, swingHigh, color=color.new(poolColor, 70), style=line.style_dotted, width=1) : line.new(na, na, na, na)
        array.push(eqHighLines, ln)

// ─── PROCESS SWING LOWS → EQUAL LOWS ─────────────────────────────────────────
if not na(swingLow)
    swingBar = bar_index - swingLen
    matched = false

    if array.size(eqLowLevels) > 0
        for i = 0 to array.size(eqLowLevels) - 1
            if not array.get(eqLowSwept, i)
                level = array.get(eqLowLevels, i)
                diff = math.abs(swingLow - level) / level * 100

                if diff <= eqThreshold
                    touches = array.get(eqLowTouches, i) + 1
                    array.set(eqLowTouches, i, touches)
                    array.set(eqLowBars, i, swingBar)
                    newLevel = (level * (touches - 1) + swingLow) / touches
                    array.set(eqLowLevels, i, newLevel)

                    if showPools
                        oldLine = array.get(eqLowLines, i)
                        line.delete(oldLine)
                        firstBar = array.get(eqLowFirstBar, i)
                        newLine = line.new(
                             firstBar, newLevel,
                             bar_index, newLevel,
                             color = poolColor,
                             style = line.style_dashed,
                             width = touches >= minTouches ? 2 : 1
                             )
                        array.set(eqLowLines, i, newLine)

                    matched := true
                    break

    if not matched
        array.push(eqLowLevels, swingLow)
        array.push(eqLowTouches, 1)
        array.push(eqLowBars, swingBar)
        array.push(eqLowFirstBar, swingBar)
        array.push(eqLowSwept, false)

        ln = showPools ? line.new(swingBar, swingLow, bar_index, swingLow, color=color.new(poolColor, 70), style=line.style_dotted, width=1) : line.new(na, na, na, na)
        array.push(eqLowLines, ln)

// ─── SWEEP DETECTION ─────────────────────────────────────────────────────────
// Bullish sweep: price wicks BELOW equal lows then closes back above
//   → stop hunt below, potential reversal to upside
//
// Bearish sweep: price wicks ABOVE equal highs then closes back below
//   → stop hunt above, potential reversal to downside

// Check equal highs for bearish sweep
if array.size(eqHighLevels) > 0
    for i = array.size(eqHighLevels) - 1 to 0
        if array.get(eqHighSwept, i)
            continue

        level   = array.get(eqHighLevels, i)
        touches = array.get(eqHighTouches, i)
        poolBar = array.get(eqHighBars, i)
        age     = bar_index - poolBar

        // Cleanup old pools
        if age > maxPoolAge
            line.delete(array.get(eqHighLines, i))
            array.remove(eqHighLevels, i)
            array.remove(eqHighTouches, i)
            array.remove(eqHighBars, i)
            array.remove(eqHighFirstBar, i)
            array.remove(eqHighSwept, i)
            array.remove(eqHighLines, i)
            continue

        // Only sweep pools with enough touches
        if touches < minTouches
            continue

        // Bearish sweep: wick above level, close below
        wickAbove = high > level
        closedBelow = close < level
        wickSize = (high - level) / level * 100

        if wickAbove and closedBelow and wickSize >= sweepWickPct
            array.set(eqHighSwept, i, true)

            // Dim the pool line
            ln = array.get(eqHighLines, i)
            line.set_color(ln, color.new(poolColor, 85))
            line.set_style(ln, line.style_dotted)

            if showSweeps
                tooltipText = "SWEEP|BEARISH|" + str.tostring(level, "#.##") + "|" + str.tostring(touches) + "|" + str.tostring(bar_index)

                label.new(
                     bar_index, high,
                     "SWEEP ▼\n" + str.tostring(level, "#.##"),
                     style     = label.style_label_down,
                     color     = bearColor,
                     textcolor = color.white,
                     size      = size.small,
                     tooltip   = tooltipText
                     )

// Check equal lows for bullish sweep
if array.size(eqLowLevels) > 0
    for i = array.size(eqLowLevels) - 1 to 0
        if array.get(eqLowSwept, i)
            continue

        level   = array.get(eqLowLevels, i)
        touches = array.get(eqLowTouches, i)
        poolBar = array.get(eqLowBars, i)
        age     = bar_index - poolBar

        if age > maxPoolAge
            line.delete(array.get(eqLowLines, i))
            array.remove(eqLowLevels, i)
            array.remove(eqLowTouches, i)
            array.remove(eqLowBars, i)
            array.remove(eqLowFirstBar, i)
            array.remove(eqLowSwept, i)
            array.remove(eqLowLines, i)
            continue

        if touches < minTouches
            continue

        // Bullish sweep: wick below level, close above
        wickBelow = low < level
        closedAbove = close > level
        wickSize = (level - low) / level * 100

        if wickBelow and closedAbove and wickSize >= sweepWickPct
            array.set(eqLowSwept, i, true)

            ln = array.get(eqLowLines, i)
            line.set_color(ln, color.new(poolColor, 85))
            line.set_style(ln, line.style_dotted)

            if showSweeps
                tooltipText = "SWEEP|BULLISH|" + str.tostring(level, "#.##") + "|" + str.tostring(touches) + "|" + str.tostring(bar_index)

                label.new(
                     bar_index, low,
                     "SWEEP ▲\n" + str.tostring(level, "#.##"),
                     style     = label.style_label_up,
                     color     = bullColor,
                     textcolor = color.white,
                     size      = size.small,
                     tooltip   = tooltipText
                     )

// ─── EXTEND POOL LINES ───────────────────────────────────────────────────────
if array.size(eqHighLines) > 0
    for i = 0 to array.size(eqHighLines) - 1
        if not array.get(eqHighSwept, i) and showPools
            line.set_x2(array.get(eqHighLines, i), bar_index)

if array.size(eqLowLines) > 0
    for i = 0 to array.size(eqLowLines) - 1
        if not array.get(eqLowSwept, i) and showPools
            line.set_x2(array.get(eqLowLines, i), bar_index)

// ─── INFO TABLE ──────────────────────────────────────────────────────────────
var table infoTable = table.new(position.middle_right, 2, 6, bgcolor=color.new(color.black, 80), border_width=1)

if barstate.islast
    activeHighPools = 0
    activeLowPools = 0
    nearestAbove = ""
    nearestBelow = ""
    nearestAboveDist = 999999999.0
    nearestBelowDist = 999999999.0

    // Count active high pools & find nearest
    if array.size(eqHighLevels) > 0
        for i = 0 to array.size(eqHighLevels) - 1
            if not array.get(eqHighSwept, i) and array.get(eqHighTouches, i) >= minTouches
                activeHighPools += 1
                level = array.get(eqHighLevels, i)
                dist = math.abs(close - level)
                if dist < nearestAboveDist and level > close
                    nearestAboveDist := dist
                    nearestAbove := str.tostring(level, "#.##") + " (" + str.tostring(array.get(eqHighTouches, i)) + "x)"

    // Count active low pools & find nearest
    if array.size(eqLowLevels) > 0
        for i = 0 to array.size(eqLowLevels) - 1
            if not array.get(eqLowSwept, i) and array.get(eqLowTouches, i) >= minTouches
                activeLowPools += 1
                level = array.get(eqLowLevels, i)
                dist = math.abs(close - level)
                if dist < nearestBelowDist and level < close
                    nearestBelowDist := dist
                    nearestBelow := str.tostring(level, "#.##") + " (" + str.tostring(array.get(eqLowTouches, i)) + "x)"

    table.cell(infoTable, 0, 0, "Liquidity Sweep",     text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 0, "",                     text_color=color.white, text_size=size.small)

    table.cell(infoTable, 0, 1, "Liq Above",            text_color=color.gray,  text_size=size.small)
    table.cell(infoTable, 1, 1, str.tostring(activeHighPools) + " pools", text_color=bearColor, text_size=size.small)

    table.cell(infoTable, 0, 2, "Liq Below",            text_color=color.gray,  text_size=size.small)
    table.cell(infoTable, 1, 2, str.tostring(activeLowPools) + " pools", text_color=bullColor, text_size=size.small)

    table.cell(infoTable, 0, 3, "Nearest Above",        text_color=color.gray,  text_size=size.small)
    table.cell(infoTable, 1, 3, nearestAbove == "" ? "—" : nearestAbove, text_color=bearColor, text_size=size.small)

    table.cell(infoTable, 0, 4, "Nearest Below",        text_color=color.gray,  text_size=size.small)
    table.cell(infoTable, 1, 4, nearestBelow == "" ? "—" : nearestBelow, text_color=bullColor, text_size=size.small)

    // Last sweep info
    table.cell(infoTable, 0, 5, "Threshold",            text_color=color.gray,  text_size=size.small)
    table.cell(infoTable, 1, 5, str.tostring(eqThreshold, "#.##") + "% / " + str.tostring(minTouches) + " touches", text_color=color.white, text_size=size.small)
