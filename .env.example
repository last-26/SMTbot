BYBIT_API_KEY=your_demo_api_key
BYBIT_API_SECRET=your_demo_secret
BYBIT_DEMO=1

TV_MCP_PORT=9222
LOG_LEVEL=INFO

# Operator-set absolute $R per trade (2026-04-20). When set, every position
# sizes so realized SL loss ≈ this USDT amount regardless of live total
# equity shimmer from concurrent open positions. Leave empty/unset to use
# `trading.risk_per_trade_pct` percent mode from config/default.yaml. Wins
# over the YAML value when both are set. Safety rail: value must be ≤ 10%
# of account_balance. Bump manually as balance grows.
# Example: RISK_AMOUNT_USDT=50.0  → each SL hit loses ≈ $50, each TP pays
# ≈ 3 × $50 = $150 (before fees) under the hard 1:3 RR contract.
RISK_AMOUNT_USDT=

# Phase 1.5 — derivatives data layer (Coinalyze REST).
# Free tier at https://coinalyze.net/api-access — 40 req/min.
COINALYZE_API_KEY=

# Macro event blackout (Finnhub primary, FairEconomy secondary).
# Free tier at https://finnhub.io/dashboard — 60 req/min.
FINNHUB_API_KEY=

# 2026-04-21 — Arkham on-chain enrichment (trial 30-day key).
# Not required unless `on_chain.enabled: true` in config/default.yaml.
# Client auto-disables when reported label-usage crosses
# `on_chain.api_usage_auto_disable_pct` (default 95%). See CLAUDE.md
# 2026-04-21 Arkham integration changelog for rollback procedure.
ARKHAM_API_KEY=
