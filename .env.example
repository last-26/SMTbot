BYBIT_API_KEY=your_demo_api_key
BYBIT_API_SECRET=your_demo_secret
BYBIT_DEMO=1

TV_MCP_PORT=9222
LOG_LEVEL=INFO

# Optional manual $R override (escape hatch). Default: auto mode sizes R
# from `trading.auto_risk_pct_of_wallet` × realized wallet balance.
# Uncomment + set to pin a flat $R, ignoring auto mode.
# RISK_AMOUNT_USDT=10

# Coinalyze (derivatives REST). Free tier 40 req/min.
COINALYZE_API_KEY=

# Finnhub (macro event blackout). Free tier 60 req/min.
FINNHUB_API_KEY=

# Arkham (on-chain enrichment). Required only when on_chain.enabled=true.
ARKHAM_API_KEY=
